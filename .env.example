# ─────────────────────────────────────────────────────────────────────────────
# Voice-to-Text + Text Translator — Environment Configuration
# Copy to .env and adjust as needed:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Whisper (Voice-to-Text) ──────────────────────────────────────────────────

# Whisper model size — options: tiny, base, small, medium, large-v3, large-v3-turbo
# "large-v3-turbo" offers the best speed/quality trade-off.
WHISPER_MODEL=large-v3-turbo

# Device: "cpu" or "cuda" (GPU). Ignored when using docker compose --profile gpu.
WHISPER_DEVICE=cpu

# Compute type: int8 (CPU, fast), float16 (GPU), float32 (high precision)
WHISPER_COMPUTE_TYPE=int8

# Beam size for decoding — higher = more accurate but slower (default: 5)
WHISPER_BEAM_SIZE=5

# Maximum upload size in megabytes
MAX_UPLOAD_MB=500

# ── Translation & Text Processing (Ollama) ───────────────────────────────────

# Translation model — "translategemma:12b" is purpose-built for translation.
# Alternatives: translategemma:4b (less VRAM), gemma3:12b (general-purpose)
TRANSLATION_MODEL=translategemma:12b

# Processing model — used for summarization, text optimization, custom prompts.
# "gemma3:12b" is the best balance of quality and resource usage.
# Alternatives: gemma3:4b (less VRAM), llama3.2:3b (minimal hardware)
PROCESSING_MODEL=gemma3:12b

# Maximum text length for translation / processing (characters)
MAX_TEXT_LENGTH=10000

# ── Port Mappings ────────────────────────────────────────────────────────────

API_PORT=8000           # Whisper API
TEXT_API_PORT=5000      # Text API (translation + processing)
OLLAMA_PORT=11434       # Ollama LLM runtime
WEB_PORT=1234           # Voice-to-Text frontend
TRANSLATOR_PORT=1235    # Text Translator frontend
